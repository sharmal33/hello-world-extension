  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint src/ --ext .js,.jsx,.ts,.tsx",
    "start": "react-native start",
    "test": "jest --coverage",
    "android-dev": "react-native run-android --mode=developmentDebug --appIdSuffix dev",
    "ios-dev": "react-native run-ios --scheme=HelloWorldSDK-Development",
    "android-staging": "react-native run-android --mode=stagingDebug --appIdSuffix staging",
    "ios-staging": "react-native run-ios --scheme=HelloWorldSDK-Staging",
    "android-prod": "react-native run-android --mode=productionDebug",
    "ios-prod": "react-native run-ios --scheme=HelloWorldSDK-Production",
    "postinstall": "patch-package && npx react-native-asset",
    "format": "npx prettier --write .",
    "build-android": "export ENVFILE=.env.staging && cd android && ./gradlew assembleRelease",
    "install-pod": "bundle install && bundle exec pod install --project-directory=ios"
  },
